CLERK_CLIENT_ID=replace-with-oauth-client-id
CLERK_CLIENT_SECRET=replace-with-oauth-client-secret
CLERK_REDIRECT_URI=http://localhost:8501
CLERK_FAPI_URL=https://your-clerk-frontend-api.clerk.accounts.dev